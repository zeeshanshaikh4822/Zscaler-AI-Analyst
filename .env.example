# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Zscaler OneAPI OAuth2 credentials
# Create a client in: Admin > API > API Key Management
ZSCALER_CLIENT_ID=your-client-id
ZSCALER_CLIENT_SECRET=your-client-secret

# Your Zscaler cloud (check Admin > About for your cloud)
# Examples: zscaler.net | zscalerone.net | zscalertwo.net | zscalerthree.net | zscloud.net
ZSCALER_CLOUD=zscalerthree.net

# Your org's Zscaler login domain (found in Admin > Authentication > Authentication Profile)
# Example: yourcompany.zslogin.net
ZSCALER_VANITY_DOMAIN=yourcompany.zslogin.net
